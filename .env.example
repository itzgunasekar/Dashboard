# ============================================
# AETHER TRADING PLATFORM - ENVIRONMENT CONFIG
# Copy this to .env.local and fill in real values
# ============================================

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/aether_db?schema=public"

# --- NextAuth / JWT ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-64"
JWT_SECRET="generate-with-openssl-rand-base64-32"
JWT_REFRESH_SECRET="generate-with-openssl-rand-base64-32"

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# --- MetaApi (MT5 Broker Connection) ---
METAAPI_TOKEN="your-metaapi-token"
METAAPI_DOMAIN="agiliumtrade.agiliumtrade.ai"

# --- Broker IB Configuration ---
IB_REFERRAL_CODE="AETHER-IB-001"
IB_BROKER_NAME="ICMarkets"
IB_ACCOUNT_OPEN_URL="https://www.icmarkets.com/open-account?ref=AETHER-IB-001"

# --- Email (Nodemailer) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="noreply@aether.trading"
SMTP_PASS="app-specific-password"
EMAIL_FROM="AETHER Trading <noreply@aether.trading>"

# --- Security ---
ENCRYPTION_KEY="32-byte-hex-key-for-aes-256"
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- App ---
NEXT_PUBLIC_APP_URL="https://aether.trading"
NEXT_PUBLIC_APP_NAME="AETHER"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
